{
  "name": "wired-action-tool-threw",
  "description": "Wired-action tool throws synchronously (or rejects). Router catches, emits `_ggui:contract-error` with code TOOL_THREW + sanitized causedBy. Render survives — the probe UI stays interactive. Matches `runtime-contract.spec.ts::tool-throws`.",
  "skipReason": null,
  "setup": [
    { "type": "create-session", "sessionId": "ck-tool-threw-1" },
    { "type": "register-tool", "toolName": "tasks_broken", "handler": "throw" },
    { "type": "register-actionspec", "name": "triggerBroken", "tool": "tasks_broken" }
  ],
  "inputEnvelope": {
    "type": "action",
    "channel": 0,
    "sessionId": "ck-tool-threw-1",
    "action": {
      "name": "triggerBroken",
      "data": {}
    }
  },
  "expectedBehavior": {
    "kind": "contract-error",
    "code": "TOOL_THREW",
    "toolName": "tasks_broken",
    "actionName": "triggerBroken",
    "sourceAction": "wired-action",
    "observability": {
      "kind": "contract-error-emitted",
      "code": "TOOL_THREW",
      "toolName": "tasks_broken"
    }
  }
}
