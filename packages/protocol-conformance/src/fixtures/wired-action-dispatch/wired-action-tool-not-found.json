{
  "name": "wired-action-tool-not-found",
  "description": "Wired-action dispatch names an action whose declared tool is not registered on the render. The router MUST emit a `_ggui:contract-error` envelope with code TOOL_NOT_FOUND and a matching `contract-error-emitted` observability event. Render stays alive.",
  "skipReason": null,
  "setup": [
    { "type": "create-render", "renderId": "ck-tool-not-found-1" },
    { "type": "register-tool", "toolName": "known-tool", "handler": "echo" }
  ],
  "inputEnvelope": {
    "type": "action",
    "channel": 0,
    "renderId": "ck-tool-not-found-1",
    "action": {
      "name": "doesNotExist",
      "data": {}
    }
  },
  "expectedBehavior": {
    "kind": "contract-error",
    "code": "TOOL_NOT_FOUND",
    "toolName": "doesNotExist",
    "actionName": "doesNotExist",
    "sourceAction": "wired-action",
    "observability": {
      "kind": "contract-error-emitted",
      "code": "TOOL_NOT_FOUND",
      "toolName": "doesNotExist"
    }
  },
  "teardown": [{ "type": "close-render", "renderId": "ck-tool-not-found-1" }]
}
