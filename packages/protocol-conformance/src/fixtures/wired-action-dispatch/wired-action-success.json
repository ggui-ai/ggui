{
  "name": "wired-action-success",
  "description": "Happy-path wired-action dispatch. A declared action tool fires, the refresh-stream tool follows, and the renderer emits a `wired-tool-invoked` observability event for each invocation. Baseline proof that the protocol's declare+wire+no-agent-code claim works end-to-end.",
  "skipReason": null,
  "setup": [
    { "type": "create-session", "sessionId": "ck-wired-success-1" },
    { "type": "register-tool", "toolName": "tasks_complete", "handler": "echo" },
    { "type": "register-tool", "toolName": "tasks_list", "handler": "echo" },
    { "type": "register-actionspec", "name": "toggleTask", "tool": "tasks_complete" }
  ],
  "inputEnvelope": {
    "type": "action",
    "channel": 0,
    "sessionId": "ck-wired-success-1",
    "action": {
      "name": "toggleTask",
      "data": { "id": "seed-1" }
    }
  },
  "expectedBehavior": {
    "kind": "observability-event",
    "event": {
      "kind": "wired-tool-invoked",
      "toolName": "tasks_complete",
      "actionName": "toggleTask"
    }
  },
  "expectedObservability": [
    {
      "kind": "wired-tool-invoked",
      "toolName": "tasks_complete",
      "actionName": "toggleTask"
    }
  ],
  "teardown": [{ "type": "close-session", "sessionId": "ck-wired-success-1" }]
}
