{
  "name": "stream-refresh-success",
  "description": "Happy-path refresh: a wired action succeeds, the declared `streamSpec[channel].tool` refresh tool fires, and the channel's next stream-update reflects the new snapshot. Proves the refresh-after-action contract is observable on the wire (not only on the DOM).",
  "skipReason": null,
  "setup": [
    { "type": "create-render", "renderId": "ck-refresh-success-1" },
    { "type": "register-tool", "toolName": "tasks_create", "handler": "echo" },
    { "type": "register-tool", "toolName": "tasks_list", "handler": "list-snapshot" },
    { "type": "register-actionspec", "name": "createTask", "tool": "tasks_create" },
    { "type": "register-streamspec", "channel": "tasks", "tool": "tasks_list" }
  ],
  "inputEnvelope": {
    "type": "action",
    "channel": 0,
    "renderId": "ck-refresh-success-1",
    "action": {
      "name": "createTask",
      "data": { "title": "ck-refresh" }
    }
  },
  "expectedBehavior": {
    "kind": "stream-update",
    "channel": "tasks",
    "value": {
      "items": []
    }
  },
  "expectedObservability": [
    {
      "kind": "wired-tool-invoked",
      "toolName": "tasks_create",
      "actionName": "createTask"
    },
    {
      "kind": "wired-tool-invoked",
      "toolName": "tasks_list"
    }
  ]
}
