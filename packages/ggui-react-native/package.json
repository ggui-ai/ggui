{
  "name": "@ggui-ai/react-native",
  "version": "0.1.0-rc.1",
  "description": "React Native SDK for ggui — components and hooks for embedding agent-generated UIs in mobile apps.",
  "keywords": [
    "ggui",
    "react-native",
    "expo",
    "mcp",
    "ai-agent",
    "generative-ui",
    "sdk"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/ggui-ai/ggui/tree/main/packages/ggui-react-native",
  "repository": {
    "type": "git",
    "url": "https://github.com/ggui-ai/ggui.git",
    "directory": "packages/ggui-react-native"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./query": {
      "types": "./src/query/index.ts",
      "default": "./src/query/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    },
    "./chat-helpers": {
      "types": "./src/chat-helpers/index.ts",
      "default": "./src/chat-helpers/index.ts"
    },
    "./chat-thread": {
      "types": "./src/chat-thread/index.ts",
      "default": "./src/chat-thread/index.ts"
    },
    "./chat-thread/shells/chat": {
      "types": "./src/chat-thread/shells/chat/index.ts",
      "default": "./src/chat-thread/shells/chat/index.ts"
    },
    "./chat-thread/shells/agent": {
      "types": "./src/chat-thread/shells/agent/index.ts",
      "default": "./src/chat-thread/shells/agent/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.70.0",
    "react-native-webview": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {
    "@ggui-ai/design": "workspace:*",
    "@ggui-ai/preview-a2ui": "workspace:*",
    "@ggui-ai/iframe-runtime": "workspace:*",
    "@ggui-ai/shared": "workspace:*",
    "@ggui-ai/protocol": "workspace:*",
    "@ggui-ai/wire": "workspace:*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.0.0",
    "react": "19.0.0",
    "react-native": "0.81.5",
    "react-native-webview": "^13.16.0",
    "react-test-renderer": "19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "bugs": {
    "url": "https://github.com/ggui-ai/ggui/issues"
  }
}
