{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ggui.ai/schemas/component-spec.json",
  "title": "Component Specification",
  "description": "Schema for predefined component spec.json files",
  "type": "object",
  "required": ["name", "level", "category", "description", "visual", "interface", "examples"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug used to derive the blueprint ID. Optional — defaults to a hash of `name`. Renaming `name` while `id` is unset will rotate the blueprint ID and invalidate any agent caches keyed off it; set `id` for stability.",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "description": "PascalCase component name (e.g., LoginForm, SearchField)",
      "pattern": "^[A-Z][a-zA-Z0-9]*$"
    },
    "level": {
      "type": "string",
      "enum": ["primitive", "component", "composite", "blueprint"],
      "description": "Component level (primitive=basic elements, component=combinations, composite=complex compositions, blueprint=page layouts)"
    },
    "category": {
      "type": "string",
      "description": "Category within the level (e.g., forms, navigation, feedback)",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Brief description of what the component does",
      "minLength": 10
    },
    "visual": {
      "type": "object",
      "required": ["description", "layout", "tokens"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Visual appearance description for AI generation hints",
          "minLength": 20
        },
        "layout": {
          "type": "string",
          "description": "Layout structure (e.g., 'vertical stack', 'horizontal row', 'grid')"
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Design token paths used by this component (e.g., 'color.primary.500', 'spacing.4')"
        }
      },
      "additionalProperties": false
    },
    "interface": {
      "type": "object",
      "required": ["props", "callbacks", "slots"],
      "properties": {
        "props": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/propSpec"
          },
          "description": "Component props"
        },
        "callbacks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Callback prop names (e.g., 'onSubmit', 'onChange')"
        },
        "slots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Named slots for composition (e.g., 'header', 'footer', 'actions')"
        }
      },
      "additionalProperties": false
    },
    "examples": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/example"
      },
      "minItems": 1,
      "description": "Example prompts that should match this component"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Other predefined components this depends on"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Search tags for discovery"
    },
    "stream": {
      "type": "object",
      "description": "Optional ggui_emit data spec — describes the real-time event channels this component accepts. Free-form JSON; runtime is the source of truth for the streamSpec contract.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "definitions": {
    "propSpec": {
      "type": "object",
      "required": ["name", "type", "required", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Prop name in camelCase",
          "pattern": "^[a-z][a-zA-Z0-9]*$"
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "function", "object", "array"],
          "description": "TypeScript-like type"
        },
        "required": {
          "type": "boolean",
          "description": "Whether the prop is required"
        },
        "description": {
          "type": "string",
          "description": "What this prop does"
        },
        "defaultValue": {
          "description": "Default value if not provided"
        },
        "example": {
          "description": "Example value used in generated documentation and contract examples"
        }
      },
      "additionalProperties": false
    },
    "example": {
      "type": "object",
      "required": ["prompt", "match"],
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Example user prompt that should match this component",
          "minLength": 5
        },
        "match": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Match confidence (0-1) for this prompt"
        }
      },
      "additionalProperties": false
    }
  }
}
