{
  "name": "AgentNameCardComposite",
  "level": "composite",
  "category": "display",
  "description": "An AI agent identity card with avatar, name, description, capability badges, and feature list. Designed for agent self-introduction and identity display in playground and portal contexts.",
  "visual": {
    "description": "Sleek card with gradient header, agent avatar/icon, name and tagline, capability badges in a row, and a vertical feature list with icons.",
    "layout": "vertical stack in centered card",
    "tokens": [
      "color.primary.600",
      "color.primary.50",
      "color.neutral.200",
      "color.neutral.500",
      "color.neutral.800",
      "spacing.4",
      "spacing.6",
      "borderRadius.lg",
      "shadow.md"
    ]
  },
  "interface": {
    "props": [
      {
        "name": "name",
        "type": "string",
        "required": false,
        "description": "Agent display name",
        "defaultValue": "Sample Agent"
      },
      {
        "name": "tagline",
        "type": "string",
        "required": false,
        "description": "Short tagline or role",
        "defaultValue": "AI-Powered UI Generation"
      },
      {
        "name": "description",
        "type": "string",
        "required": false,
        "description": "Brief description of the agent"
      },
      {
        "name": "capabilities",
        "type": "array",
        "required": false,
        "description": "List of capability badge labels (array of strings, e.g. ['Streaming', 'Tool calling'])"
      },
      {
        "name": "features",
        "type": "array",
        "required": false,
        "description": "List of features with icon and label (array of { icon, label } objects)"
      }
    ],
    "callbacks": [],
    "slots": []
  },
  "examples": [
    { "prompt": "agent name card", "match": 0.95 },
    { "prompt": "agent identity card", "match": 0.95 },
    { "prompt": "agent introduction card", "match": 0.9 },
    { "prompt": "explain yourself name card", "match": 0.9 },
    { "prompt": "bot info card", "match": 0.85 },
    { "prompt": "AI agent card", "match": 0.9 },
    { "prompt": "agent profile", "match": 0.85 }
  ],
  "tags": ["agent", "identity", "card", "display", "composite", "AI", "introduction"]
}
