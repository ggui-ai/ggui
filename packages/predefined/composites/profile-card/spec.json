{
  "name": "ProfileCardComposite",
  "level": "composite",
  "category": "display",
  "description": "A user profile card with avatar, name, title, bio, stats row (followers, following, posts), and action buttons (Follow, Message). Ideal for social profiles, team directories, and user info displays.",
  "visual": {
    "description": "Centered card with avatar circle at top, name and role below, short bio text, horizontal stats row with dividers, and two action buttons side by side.",
    "layout": "vertical stack in centered card",
    "tokens": [
      "color.primary.600",
      "color.primary.50",
      "color.neutral.200",
      "color.neutral.500",
      "color.neutral.800",
      "spacing.4",
      "spacing.6",
      "borderRadius.lg",
      "shadow.md"
    ]
  },
  "interface": {
    "props": [
      {
        "name": "name",
        "type": "string",
        "required": false,
        "description": "User's display name",
        "defaultValue": "Jane Cooper"
      },
      {
        "name": "role",
        "type": "string",
        "required": false,
        "description": "User's title or role",
        "defaultValue": "Product Designer"
      },
      {
        "name": "bio",
        "type": "string",
        "required": false,
        "description": "Short bio or description"
      },
      {
        "name": "avatarUrl",
        "type": "string",
        "required": false,
        "description": "URL for the avatar image"
      },
      {
        "name": "stats",
        "type": "object",
        "required": false,
        "description": "Stats object with followers, following, and posts counts"
      }
    ],
    "callbacks": ["onFollow", "onMessage"],
    "slots": []
  },
  "examples": [
    { "prompt": "user profile card", "match": 0.95 },
    { "prompt": "profile card", "match": 0.95 },
    { "prompt": "user info card", "match": 0.9 },
    { "prompt": "team member card", "match": 0.85 },
    { "prompt": "social profile", "match": 0.85 },
    { "prompt": "contact card", "match": 0.8 },
    { "prompt": "author bio card", "match": 0.8 },
    { "prompt": "user details display", "match": 0.85 }
  ],
  "tags": ["profile", "user", "avatar", "social", "card", "display", "composite"]
}
