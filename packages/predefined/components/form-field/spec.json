{
  "name": "FormField",
  "level": "component",
  "category": "inputs",
  "description": "A labeled form field with optional error message and helper text",
  "visual": {
    "description": "Vertical stack with label on top, input in middle, and helper/error text below. Label is slightly bolder, error text is red, helper text is muted.",
    "layout": "vertical stack",
    "tokens": [
      "color.neutral.700",
      "color.neutral.500",
      "color.error.500",
      "spacing.1",
      "spacing.2"
    ]
  },
  "interface": {
    "props": [
      {
        "name": "label",
        "type": "string",
        "required": true,
        "description": "Label text displayed above the input"
      },
      {
        "name": "value",
        "type": "string",
        "required": false,
        "description": "Input value"
      },
      {
        "name": "placeholder",
        "type": "string",
        "required": false,
        "description": "Input placeholder text"
      },
      {
        "name": "type",
        "type": "string",
        "required": false,
        "description": "Input type (text, email, password, etc.)",
        "defaultValue": "text"
      },
      {
        "name": "error",
        "type": "string",
        "required": false,
        "description": "Error message to display"
      },
      {
        "name": "helperText",
        "type": "string",
        "required": false,
        "description": "Helper text shown below input when no error"
      },
      {
        "name": "required",
        "type": "boolean",
        "required": false,
        "description": "Whether the field is required",
        "defaultValue": false
      }
    ],
    "callbacks": ["onChange"],
    "slots": []
  },
  "examples": [
    { "prompt": "form field with label", "match": 0.9 },
    { "prompt": "labeled input", "match": 0.85 },
    { "prompt": "input with error message", "match": 0.85 },
    { "prompt": "form input with validation", "match": 0.8 }
  ],
  "tags": ["form", "input", "field", "label", "validation", "error"]
}
