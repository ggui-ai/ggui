{
  "name": "FileBrowser",
  "level": "blueprint",
  "category": "navigation",
  "description": "A file and document browser with folder navigation, breadcrumbs, list/grid view toggle, and file type icons. Ideal for document management agents and filesystem navigation.",
  "visual": {
    "description": "Top breadcrumb bar with view toggle. Main area shows files/folders as a list or grid. Each item has a type icon, name, size, and modified date. Folders are clickable for navigation.",
    "layout": "breadcrumb bar + view toggle + file list/grid",
    "tokens": [
      "color.primary.600",
      "color.primary.50",
      "color.neutral.200",
      "color.neutral.500",
      "spacing.3",
      "spacing.4",
      "borderRadius.md",
      "shadow.sm"
    ]
  },
  "interface": {
    "props": [
      {
        "name": "files",
        "type": "array",
        "required": false,
        "description": "Array of file objects with name, type (file|folder), size, modifiedAt, mimeType"
      },
      {
        "name": "currentPath",
        "type": "string",
        "required": false,
        "description": "Current directory path",
        "defaultValue": "/"
      },
      {
        "name": "title",
        "type": "string",
        "required": false,
        "description": "Browser title",
        "defaultValue": "Files"
      }
    ],
    "callbacks": ["onFileClick", "onFolderOpen", "onNavigate", "onDelete"],
    "slots": []
  },
  "examples": [
    { "prompt": "file browser", "match": 0.95 },
    { "prompt": "file manager", "match": 0.95 },
    { "prompt": "document browser", "match": 0.9 },
    { "prompt": "folder navigation", "match": 0.9 },
    { "prompt": "file explorer", "match": 0.95 },
    { "prompt": "browse files", "match": 0.9 },
    { "prompt": "show me my documents", "match": 0.8 },
    { "prompt": "file list with folders", "match": 0.85 }
  ],
  "tags": ["files", "browser", "documents", "folders", "navigation", "explorer", "blueprint"]
}
