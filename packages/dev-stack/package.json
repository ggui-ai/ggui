{
  "name": "@ggui-ai/dev-stack",
  "version": "0.3.0",
  "description": "Shared local dev engine for the ggui protocol: local UI registry discovery, compile-on-demand, filesystem watcher with SSE, and a read-only HTTP surface for dev tooling. Framework-neutral — agent runtime supervision plugs in via an adapter seam, so no agent SDK is hardcoded.",
  "keywords": [
    "ggui",
    "dev-server",
    "mcp",
    "ui-registry",
    "esbuild",
    "generative-ui"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/build-hub-preview.mjs",
    "build:hub-preview": "node scripts/build-hub-preview.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc -p hub-preview-client/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ggui-ai/agent-runtime": "workspace:*",
    "@ggui-ai/project-config": "workspace:*",
    "@ggui-ai/ui-registry": "workspace:*",
    "chokidar": "^4.0.3",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@ggui-ai/design": "workspace:*",
    "@ggui-ai/react": "workspace:*",
    "@ggui-ai/wire": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ggui-ai/ggui.git",
    "directory": "packages/dev-stack"
  },
  "homepage": "https://github.com/ggui-ai/ggui/tree/main/packages/dev-stack",
  "bugs": {
    "url": "https://github.com/ggui-ai/ggui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "ggui contributors <hello@ggui.ai>"
}
