{
  "name": "@ggui-ai/react",
  "version": "0.3.0",
  "description": "React SDK for ggui — components and hooks for embedding agent-generated UIs in web apps.",
  "keywords": [
    "ggui",
    "react",
    "mcp",
    "ai-agent",
    "generative-ui",
    "websocket",
    "sdk"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/ggui-ai/ggui/tree/main/packages/ggui-react",
  "repository": {
    "type": "git",
    "url": "https://github.com/ggui-ai/ggui.git",
    "directory": "packages/ggui-react"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "import": "./dist/query/index.mjs",
      "require": "./dist/query/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.js"
    },
    "./shells": {
      "types": "./dist/shells/index.d.ts",
      "import": "./dist/shells/index.mjs",
      "require": "./dist/shells/index.js"
    },
    "./chat-helpers": {
      "types": "./dist/chat-helpers/index.d.ts",
      "import": "./dist/chat-helpers/index.mjs",
      "require": "./dist/chat-helpers/index.js"
    },
    "./chat-thread": {
      "types": "./dist/chat-thread/index.d.ts",
      "import": "./dist/chat-thread/index.mjs",
      "require": "./dist/chat-thread/index.js"
    },
    "./chat-thread/shells/chat": {
      "types": "./dist/chat-thread/shells/chat/index.d.ts",
      "import": "./dist/chat-thread/shells/chat/index.mjs",
      "require": "./dist/chat-thread/shells/chat/index.js"
    },
    "./chat-thread/shells/agent": {
      "types": "./dist/chat-thread/shells/agent/index.d.ts",
      "import": "./dist/chat-thread/shells/agent/index.mjs",
      "require": "./dist/chat-thread/shells/agent/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {
    "@ggui-ai/preview-a2ui": "workspace:*",
    "@ggui-ai/protocol": "workspace:*",
    "@ggui-ai/iframe-runtime": "workspace:*",
    "@ggui-ai/shared": "workspace:*",
    "@ggui-ai/wire": "workspace:*",
    "@mcp-ui/client": "^7.1.1"
  },
  "devDependencies": {
    "@ggui-ai/design": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "bugs": {
    "url": "https://github.com/ggui-ai/ggui/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "ggui contributors <hello@ggui.ai>"
}
