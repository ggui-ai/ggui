# Brand-agnostic MCP-Apps agent backend URL.
#
# Points at any MCP-Apps-spec agent server — the included reference
# samples (oss/samples/agents/claude-agent-sdk / openai-agents-sdk /
# google-adk) all expose the same wire:
#
#   POST /chat            (SSE stream of SDK messages)
#   GET  /chat?chatId=X   (snapshot replay)
#   POST /relay/tools-call
#   GET  /api/renders/:id/state
#
# All three reference samples default the agent backend to 6790, so this
# works as-is. Override only if you ran the agent on a different PORT.
#
# Must be VITE_-prefixed so Vite exposes it to the browser bundle (vars
# without the prefix stay server-only). The SPA fetches the SSE stream
# and snapshot directly from the browser — there is no server-side
# proxy in the loop, just the agent backend on the URL below.
VITE_AGENT_ENDPOINT_URL=http://localhost:6790
