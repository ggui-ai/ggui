# Brand-agnostic MCP-Apps agent backend URL.
#
# Points at any MCP-Apps-spec agent server — the included reference
# samples (oss/samples/agents/claude-agent-sdk / openai-agents-sdk /
# google-adk) all expose the same wire:
#
#   POST /chat            (SSE stream of SDK messages)
#   GET  /chat?chatId=X   (snapshot replay)
#   POST /relay/tools-call
#   GET  /api/renders/:id/state
#
# Default reflects the e2e harness layout (claude-agent-sdk on 6790).
# Change to 6791 (openai) or 6792 (google) to swap upstream SDKs.
#
# Must be NEXT_PUBLIC_-prefixed so the browser bundle picks it up; the
# Next.js app fetches the SSE stream and snapshot directly from the
# browser, no server-side proxy in the loop.
NEXT_PUBLIC_AGENT_ENDPOINT_URL=http://localhost:6790
