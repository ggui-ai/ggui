# pnpm configuration for the standalone github.com/ggui-ai/ggui repo.
# (this directory is the subtree-split root, so this file lands at the
# repo root there.) All pnpm-flavored settings (auto-install-peers,
# strict-peer-dependencies, node-linker, etc.) moved to
# pnpm-workspace.yaml in the pnpm 11 upgrade — pnpm 11 no longer
# reads them from .npmrc. Only npm-standard settings remain here.
engine-strict=true
