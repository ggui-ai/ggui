# Copy to `.env.local` (git-ignored). Both the agent AND `ggui serve`
# read this file: the agent walks up the directory tree to find it;
# `pnpm dev:ggui` and `pnpm dev:agent` source it via dotenv-cli.

# --- Required ---

# Anthropic API key — drives both the agent (claude-agent-sdk) and
# ggui's own UI generation. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Wire the todo MCP into the agent (needed for the full demo) ---

# Set this so the agent registers the todo MCP server's tools alongside
# the ggui_* render tools. Leave unset to run the agent against ggui only.
GGUI_TODO_MCP_URL=http://localhost:6782/mcp

# --- Optional overrides (defaults shown) ---

# Where the agent's MCP client connects for ggui_* (render) tools.
# GGUI_MCP_URL=http://localhost:6781/mcp

# Bearer sent on every ggui MCP request. The default pairs with
# `ggui serve --dev-allow-all`, which accepts any non-empty bearer.
# GGUI_MCP_BEARER=dev

# Claude model — bump to a stronger model for richer UI generation.
# Options: claude-haiku-4-5-20251001 · claude-sonnet-4-6 · claude-opus-4-7
# MODEL=claude-haiku-4-5-20251001

# Agent backend HTTP port.
# PORT=6790

# Frontend SPA — where the browser bundle should hit the agent backend.
# Default works for `pnpm dev:web` against `pnpm dev:agent` on the same host.
# VITE_AGENT_ENDPOINT_URL=http://localhost:6790
